# HOCAI Server — Environment Configuration
# Copy this file to .env and fill in your values

# AI API (OpenAI-compatible format)
AI_API_URL=http://localhost:11434/v1
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-3.5-turbo

# Server settings
HOCAI_PORT=8000
HOCAI_HOST=127.0.0.1

# Scoring thresholds (optional, defaults shown)
# SCORE_READY_THRESHOLD=70

# BrightData MCP Server (optional, for web search tool calling)
BRIGHTDATA_MCP_URL=https://mcp.brightdata.com/sse?groups=advanced_scraping
BRIGHTDATA_API_KEY=your-brightdata-token-here
